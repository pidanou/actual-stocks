# Actual Budget server connection
ACTUAL_SERVER_URL=https://actual.example.com
ACTUAL_PASSWORD=changeme
ACTUAL_SYNC_ID=1cfdbb80-6274-49bf-b0c2-737235a4c81f
# Only needed if the budget file itself is end-to-end encrypted
#ACTUAL_ENCRYPTION_PASSWORD=

# Target accounts: comma-separated, set one or both (results are merged)
ACTUAL_ACCOUNT_IDS=
#ACTUAL_ACCOUNT_NAMES=Investments,PEA

# Your budget's currency. If set, quotes in a different currency are converted
# using Yahoo Finance FX rates before being written.
#TARGET_CURRENCY=EUR

# Cron schedule (default: every day at 18:00 container-local time)
CRON_SCHEDULE=0 18 * * *
TZ=Europe/Paris

# If true, also run once immediately when the container starts
RUN_ON_START=false
